{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "scenarios/*.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/lead/?$", "dest": "/api/lead.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
