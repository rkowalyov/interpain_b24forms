{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "scenarios/*.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/event-register/?$",
      "dest": "/event-register.html"
    },
    {
      "src": "^/api/lead/?$",
      "dest": "/api/lead.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
