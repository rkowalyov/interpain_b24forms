{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "scenarios/*.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/event-register/?$",
      "dest": "/event-register.html"
    },
    {
      "src": "^/api/loader/?$",
      "dest": "/api/loader.js"
    },
    {
      "src": "^/api/lead/?$",
      "dest": "/api/lead.js"
    },
    {
      "src": "^/api/calendar-webhook/?$",
      "dest": "/api/calendar-webhook.js"
    },
    {
      "src": "^/api/event/(.*)$",
      "dest": "/api/event.js?id=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
